  "keyFeatures": [
    "Load environment variables from .env files with Vite-style priority",
    "Type-safe parsing with dedicated functions for booleans, dates, numbers, URLs, UUIDs, and enums",
    "Support for optional variables with maybe* variants",
    "Docker secrets integration for file-based secrets",
    "Fallback/default value support for all functions"
  ],
